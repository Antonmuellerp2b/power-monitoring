  slave_id = 1
  timeout = "10s"
  interval = "10s"
  controller = "tcp://${METER_URL}:502"
  configuration_type = "request"
  transmission_mode = "TCP"

  [[inputs.modbus.request]]
    slave_id = 1
    byte_order = "ABCD"
    register = "holding"
    fields = [      
      # Voltage L-N
      { address = 30005, name = "voltage_phase_1_10sec_avg", type = "FLOAT32" },
      { address = 30007, name = "voltage_phase_2_10sec_avg", type = "FLOAT32" },
      { address = 30009, name = "voltage_phase_3_10sec_avg", type = "FLOAT32" },

