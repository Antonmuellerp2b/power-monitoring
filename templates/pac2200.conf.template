[global_tags]
  location = "${SITE_ID}"

[agent]
  interval = "${POLL_INTERVAL_INST}"
  flush_interval = "5s"
  hostname = "telegraf"
   

##################################################
# Instantaneous values (INST)
##################################################

[[inputs.modbus]]
  name = "pac2200"
  name_override = "meter_fast"
  slave_id = 1
  timeout = "10s"
  controller = "tcp://${METER_URL}:502"
  configuration_type = "request"
  transmission_mode = "TCP"

  [[inputs.modbus.request]]
    slave_id = 1
    byte_order = "ABCD"
    register = "holding"
    fields = [      
      # Energy
      { address = 2821, name = "energy_active_import_phase_1", type = "FLOAT32" },
      { address = 2841, name = "energy_active_import_phase_2", type = "FLOAT32" },
      { address = 2861, name = "energy_active_import_phase_3", type = "FLOAT32" },
      { address = 2801, name = "energy_active_import_total", type = "FLOAT32" },

      # Voltage L-N
      { address = 1, name = "voltage_phase_1", type = "FLOAT32" },
      { address = 3, name = "voltage_phase_2", type = "FLOAT32" },
      { address = 5, name = "voltage_phase_3", type = "FLOAT32" },

      # Voltage L-L
      { address = 7, name = "voltage_line_12", type = "FLOAT32" },
      { address = 9, name = "voltage_line_23", type = "FLOAT32" },
      { address = 11, name = "voltage_line_31", type = "FLOAT32" },

      # Current
      { address = 13, name = "current_phase_1", type = "FLOAT32" },
      { address = 15, name = "current_phase_2", type = "FLOAT32" },
      { address = 17, name = "current_phase_3", type = "FLOAT32" },

      # Active Power
      { address = 25, name = "active_power_phase_1", type = "FLOAT32" },
      { address = 27, name = "active_power_phase_2", type = "FLOAT32" },
      { address = 29, name = "active_power_phase_3", type = "FLOAT32" },
      { address = 65, name = "active_power_total", type = "FLOAT32" },


      # Apparent Power
      { address = 19, name = "apparent_power_phase_1", type = "FLOAT32" },
      { address = 21, name = "apparent_power_phase_2", type = "FLOAT32" },
      { address = 23, name = "apparent_power_phase_3", type = "FLOAT32" },
      { address = 63, name = "apparent_power_total", type = "FLOAT32" },

      # Reactive Power
      { address = 31, name = "reactive_power_q1_phase_1", type = "FLOAT32" },
      { address = 33, name = "reactive_power_q1_phase_2", type = "FLOAT32" },
      { address = 35, name = "reactive_power_q1_phase_3", type = "FLOAT32" },
      { address = 67, name = "reactive_power_q1_total", type = "FLOAT32" },

      # Powerfactor per Phase
      { address = 37, name = "power_factor_phase_1", type = "FLOAT32" },
      { address = 39, name = "power_factor_phase_2", type = "FLOAT32" },
      { address = 41, name = "power_factor_phase_3", type = "FLOAT32" },
      { address = 69, name = "power_factor_total", type = "FLOAT32" },

      # Frequency
      { address = 55, name = "frequency", type = "FLOAT32" }
    ]


##################################################
      # 10-second-average values (AVG1)
##################################################
[[inputs.modbus]]
